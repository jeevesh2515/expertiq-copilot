# ═══════════════════════════════════════
# ExpertIQ Copilot — Environment Variables
# ═══════════════════════════════════════
# Copy this file to .env and fill in your values
# NEVER commit the .env file to version control

# ── LLM Provider (Groq — free tier) ──
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-70b-versatile

# ── JWT Authentication ──
JWT_SECRET_KEY=generate_a_64_char_random_string_here_use_openssl_rand_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ──
DATABASE_URL=postgresql://postgres:your_secure_password_here@localhost:5432/expertiq

# ── ChromaDB Vector Store ──
CHROMA_PERSIST_DIR=./chroma_db

# ── Frontend ──
FRONTEND_URL=http://localhost:3000

# ── Rate Limiting ──
RATE_LIMIT_PER_MINUTE=10

# ── Embedding Model ──
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── App Settings ──
APP_ENV=development
LOG_LEVEL=INFO

# ── LangSmith Tracing & Observability ──
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=expertiq-copilot

# ── Seed Users (set credentials via env vars — never hardcode) ──
SEED_DEMO_EMAIL=demo@expertiq.ai
SEED_DEMO_PASSWORD=your_demo_password_here
SEED_DEMO_NAME=Demo User
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=your_admin_password_here
SEED_ADMIN_NAME=Admin User
